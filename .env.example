# =============================================================================
# Copia este archivo a `.env` y rellena los valores.
# Nada de esto debe ir en el código fuente.
# =============================================================================

# --- Beehiiv (solo servidor: sin prefijo VITE_) ---
# URL base de la API v2 (sin barra final)
BEEHIIV_API_BASE=https://api.beehiiv.com/v2

# Clave API (Bearer) desde el panel de Beehiiv
BEEHIIV_API_KEY=

# ID de publicación con prefijo (ej. pub_xxxx)
BEEHIIV_PUBLICATION_ID=

# Etiqueta que se aplica al suscriptor (debe existir o Beehiiv la crea)
BEEHIIV_SUBSCRIBE_TAG=vibe coding

# Parámetros UTM del alta por API
BEEHIIV_UTM_SOURCE=links-os
BEEHIIV_UTM_MEDIUM=vibe-coding-screen

# --- Cliente (Vite solo expone variables que empiezan por VITE_) ---
# Enlace público “Ver la Comunidad” en el diálogo de éxito
VITE_SA_COMMUNITY_URL=

# Email de contacto para derechos RGPD (se muestra en la UI)
VITE_PRIVACY_CONTACT_EMAIL=

# Site key público de Cloudflare Turnstile (cliente)
VITE_TURNSTILE_SITE_KEY=

# --- Seguridad API ---
# Activa la verificación anti-bot server-side si lo completas
TURNSTILE_SECRET_KEY=

# Hostname esperado en la respuesta de Turnstile (opcional)
TURNSTILE_EXPECTED_HOSTNAME=

# Lista opcional de orígenes permitidos (coma separada) para /api/subscribe
# Ejemplo: https://mi-dominio.com,https://www.mi-dominio.com
ALLOWED_SUBSCRIBE_ORIGINS=
